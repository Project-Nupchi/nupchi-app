# Cloud Run 추론 API. Supabase와 함께 설정되면 실제 데이터 모드로 동작합니다.
EXPO_PUBLIC_INFERENCE_URL=https://nupchi-inference-301502504998.asia-northeast3.run.app

# 프론트 공개용 Supabase 값입니다. service role/secret 키는 절대 넣지 않습니다.
EXPO_PUBLIC_SUPABASE_URL=https://example.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# 로그인 없이 사용할 단일 어가 UUID입니다. 프론트 공개값이며 반드시 설정합니다.
EXPO_PUBLIC_FARM_ID=464a0fe1-aa31-4f84-a01c-c1b42cbb1126
# 변환 완료된 업로드 이미지 한도. 백엔드 확정 전 기본값은 6 MiB입니다.
EXPO_PUBLIC_MAX_UPLOAD_BYTES=6291456

# 실제 환경값이 있어도 로컬 샘플 데이터로 실행하려면 true로 설정합니다.
EXPO_PUBLIC_USE_MOCK_API=false
